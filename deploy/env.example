# /opt/ddm/.env — variables d'environnement pour le container DDM en production.
# NE PAS COMMITER. Renseigner les valeurs réelles puis chmod 600.

# ----- Base de données PostgreSQL (Neon) -----
DATABASE_URL="postgresql://user:password@host.neon.tech/DDM?sslmode=require"

# ----- NextAuth -----
# IMPORTANT : NEXTAUTH_URL doit refléter l'URL publique réelle.
NEXTAUTH_URL="http://204.168.150.125/ddm"
# Générer un secret aléatoire : openssl rand -base64 32
NEXTAUTH_SECRET="changeme-generer-avec-openssl-rand-base64-32"

# ----- OAuth Google (optionnel) -----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ----- Workspace par défaut (pour signup OAuth) -----
DEFAULT_WORKSPACE_ID=""
